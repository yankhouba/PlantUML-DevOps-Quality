<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">
<module name="Checker">

    <!-- Vérifie qu'il n'y a pas de tabulations dans le code -->
    <!-- FileTabCharacter doit être DANS Checker, pas dans TreeWalker -->
    <module name="FileTabCharacter"/>

    <module name="TreeWalker">

        <!-- Vérifie que les blocs vides sont interdits ex: if(){} -->
        <module name="EmptyBlock"/>

        <!-- Vérifie que les accolades sont présentes partout -->
        <module name="NeedBraces"/>

        <!-- Vérifie que les lignes ne dépassent pas 120 caractères -->
        <module name="LineLength">
            <property name="max" value="120"/>
        </module>

    </module>

</module>


